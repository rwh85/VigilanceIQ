{
  "expo": {
    "name": "VigilanceIQ",
    "slug": "vigilanceiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vigilanceiq",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vigilanceiq.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "VigilanceIQ reads your sleep data to predict alertness levels and provide personalized caffeine recommendations.",
        "NSHealthUpdateUsageDescription": "VigilanceIQ does not write health data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.vigilanceiq.app",
      "permissions": [
        "android.permission.health.READ_SLEEP",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-sqlite",
        { "enableFTS": false }
      ]
    ]
  }
}
